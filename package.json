{
  "name": "soloist-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@lottiefiles/dotlottie-react": "^0.17.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@stomp/stompjs": "^7.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@twa-dev/sdk": "^8.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@use-gesture/react": "^10.3.1",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "gsap": "^3.14.2",
    "i18next": "^25.6.3",
    "motion": "^12.34.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.3.5",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^3.4.0",
    "typescript": "^5.9.3",
    "web-vitals": "^5.1.0"
  },
  "scripts": {
    "start:dev": "node scripts/generate-version.cjs && VITE_ENV=development vite build && vite preview",
    "start:mocks": "VITE_USE_MOCKS=true node scripts/generate-version.cjs && VITE_ENV=development vite build && vite preview",
    "start:prod": "node scripts/generate-version.cjs && VITE_ENV=production vite build && vite preview",
    "start:watch": "VITE_ENV=development vite build --watch",
    "build": "node scripts/generate-version.cjs && VITE_ENV=production vite build",
    "codegen:openapi": "bunx openapi-typescript-codegen --input openapi.yml --output src/api",
    "codegen:graphql": "bunx graphql-codegen --config codegen.ts",
    "codegen:graphql-remote": "GRAPHQL_TOKEN=$GRAPHQL_TOKEN bunx graphql-codegen --config codegen.ts"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.3",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-graphql-request": "^6.4.0",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "shadcn": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.5.0"
  }
}
